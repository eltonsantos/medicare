<div id="<%= dom_id medicine %>">
  <p>
    <strong>Name:</strong>
    <%= medicine.name %>
  </p>

  <p>
    <strong>Quantity:</strong>
    <%= medicine.quantity %>
  </p>

  <p>
    <strong>Medicine validity:</strong>
    <%= medicine.medicine_validity %>
  </p>

  <p>
    <strong>Medicine insert:</strong>
    <%= medicine.medicine_insert %>
  </p>

  <p>
    <strong>Used to:</strong>
    <%= medicine.used_to %>
  </p>

  <p>
    <strong>Purchase date:</strong>
    <%= medicine.purchase_date %>
  </p>

  <p>
    <strong>User:</strong>
    <%= medicine.user_id %>
  </p>

</div>
